# Server
NODE_ENV=production
PORT=3001
BIND_HOST=127.0.0.1

# Security secrets — CHANGE THESE! Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# Database (relative path works fine)
DB_PATH=./data/homelab.db

# Initial admin (created on first run if no users exist)
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASS=changeme
